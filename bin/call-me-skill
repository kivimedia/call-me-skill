#!/usr/bin/env node
// CLI entry point. Subcommands: setup, speak, jump, daemon (start|stop|status),
// mode (TODO v0.3 - Stop hook voice mode), --version.
import { argv, exit } from 'node:process';
import { readFileSync } from 'node:fs';
import { fileURLToPath } from 'node:url';
import { join, dirname } from 'node:path';

const __dirname = dirname(fileURLToPath(import.meta.url));
const PKG_PATH = join(__dirname, '..', 'package.json');

function getVersion() {
  try {
    return JSON.parse(readFileSync(PKG_PATH, 'utf8')).version;
  } catch {
    return 'unknown';
  }
}

function help() {
  console.log(`call-me-skill v${getVersion()}

Usage:
  call-me-skill setup                  Run the first-run wizard
  call-me-skill speak "<message>"      Speak a message through your speakers
                                       (composes "{name}, calling from desktop {N}, {message}")
  call-me-skill jump <N>               Jump to desktop N (1-based)
  call-me-skill daemon start           Start the background hotkey daemon
  call-me-skill daemon stop            Stop the daemon
  call-me-skill daemon status          Show daemon status
  call-me-skill mode on | off          v0.3 - voice mode (Stop hook)
  call-me-skill --version              Print version
  call-me-skill --help                 This message

Speak options:
  --length short|medium|long           Override configured sentence length
  --no-intro                           Skip the intro music

Daemon hotkeys (after 'daemon start'):
  Double-tap Ctrl                      Jump to the desktop + window of the last call
  Win+Ctrl+1..9                        Jump to desktop 1..9

Config: ~/.config/call-me-skill/config.json
Secrets: ~/.config/call-me-skill/.env
Daemon log: ~/.config/call-me-skill/daemon.log
`);
}

async function main() {
  const args = argv.slice(2);
  if (args.length === 0 || args[0] === '--help' || args[0] === '-h') {
    help();
    return;
  }
  if (args[0] === '--version' || args[0] === '-v') {
    console.log(getVersion());
    return;
  }

  const cmd = args[0];
  const rest = args.slice(1);

  switch (cmd) {
    case 'setup': {
      const { runSetup } = await import('../src/setup.mjs');
      await runSetup();
      return;
    }
    case 'speak': {
      const { speak } = await import('../src/speak.mjs');
      const opts = {};
      const positional = [];
      for (let i = 0; i < rest.length; i++) {
        const a = rest[i];
        if (a === '--length') opts.length = rest[++i];
        else if (a === '--no-intro') opts.noIntro = true;
        else positional.push(a);
      }
      const message = positional.join(' ').trim();
      if (!message) {
        console.error('Usage: call-me-skill speak "<message>"');
        exit(2);
      }
      const result = await speak(message, opts);
      console.log(`spoken: ${result.sentence}`);
      return;
    }
    case 'jump': {
      const { jumpToDesktop } = await import('../src/desktop.mjs');
      const target = parseInt(rest[0], 10);
      if (!Number.isFinite(target) || target < 1) {
        console.error('Usage: call-me-skill jump <N>  (N is a 1-based desktop index)');
        exit(2);
      }
      const r = jumpToDesktop(target, 0);
      console.log(`jump: desktop ${r.fromIndex} -> ${r.toIndex} (${r.steps} ${r.direction})`);
      return;
    }
    case 'daemon': {
      const sub = rest[0];
      const { daemonStart, daemonStop, daemonStatusCmd } = await import('../src/daemon-cli.mjs');
      if (sub === 'start') daemonStart();
      else if (sub === 'stop') daemonStop();
      else if (sub === 'status') daemonStatusCmd();
      else {
        console.error('Usage: call-me-skill daemon start | stop | status');
        exit(2);
      }
      return;
    }
    case 'mode':
      console.error(`"${cmd}" not implemented in v0.2. Planned for v0.3.`);
      exit(2);
    default:
      console.error(`Unknown command: ${cmd}`);
      help();
      exit(2);
  }
}

main().catch((err) => {
  console.error('Error:', err.message || err);
  exit(1);
});
