# call-me-skill secrets - copy to ~/.config/call-me-skill/.env on first setup.
# The wizard handles this for you; this file only documents what's expected.

# Required: ElevenLabs API key (for TTS).
# Get one at https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=sk_your_key_here

# Optional (maintainers only - end users do NOT need this).
# Used by scripts/generate-intros.mjs to regenerate the bundled intro WAVs.
# Either point at a service account JSON file...
# GOOGLE_VERTEX_SA_JSON_FILE=C:/path/to/service-account.json
# ...or paste the JSON inline.
# GOOGLE_VERTEX_SA_JSON={"type":"service_account",...}
